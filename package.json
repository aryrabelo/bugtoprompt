{
	"name": "bugtoprompt",
	"version": "0.13.0",
	"description": "BugToPrompt — a portable bug-capture overlay that turns a bug into an AI-ready prompt",
	"keywords": [
		"react",
		"bug-report",
		"screenshot",
		"ai",
		"prompt",
		"overlay",
		"devtools"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aryrabelo/bugtoprompt.git"
	},
	"homepage": "https://github.com/aryrabelo/bugtoprompt#readme",
	"bugs": "https://github.com/aryrabelo/bugtoprompt/issues",
	"type": "module",
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"private": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema.d.ts",
			"import": "./dist/schema.js"
		},
		"./render": {
			"types": "./dist/render.d.ts",
			"import": "./dist/render.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js"
		},
		"./standalone": "./dist/bugtoprompt.global.js",
		"./styles.css": "./dist/bugtoprompt.css"
	},
	"scripts": {
		"build:esm": "tsup",
		"build:css": "tailwindcss -i src/standalone.css -o dist/bugtoprompt.css --minify",
		"build:standalone": "tsup --config tsup.standalone.config.ts",
		"build": "npm run build:esm && npm run build:css && npm run build:standalone",
		"prepare": "lefthook install; npm run build",
		"test": "vitest run",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"service:github": "node server/github-issue-service.mjs"
	},
	"peerDependencies": {
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"sideEffects": [
		"**/*.css",
		"./dist/bugtoprompt.global.js"
	],
	"dependencies": {
		"lucide-react": "^0.546.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/cli": "^4.3.1",
		"@testing-library/dom": "^10",
		"@testing-library/react": "^16",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"fake-indexeddb": "^6.2.5",
		"jsdom": "^25",
		"lefthook": "^2.1.9",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwindcss": "^4.3.1",
		"tsup": "^8",
		"typescript": "^5.7.0",
		"vitest": "^2"
	}
}
